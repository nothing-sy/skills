{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[GitHub MCP] Command completed'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "gh **",
      "git **",
      "npx **"
    ],
    "deny": []
  }
}
