{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[GitHub MCP] Command completed'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "gh **",
      "git **",
      "npx **"
    ],
    "deny": []
  }
}
